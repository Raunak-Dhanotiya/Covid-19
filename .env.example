# =============================================================================
# 🔐 Environment Variables — COVID-19 Tracker
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ⚠️  NEVER commit the .env file to version control!
# =============================================================================

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=covid19
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# JDBC URL (used by Spring Boot)
# Local:  jdbc:postgresql://localhost:5432/covid19
# Docker: jdbc:postgresql://postgres:5432/covid19
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/covid19
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_secure_password_here

# ── JWT Authentication ───────────────────────────────────────────────────────
# Must be at least 256-bit (32+ characters) for HMAC-SHA
JWT_SECRET=replace_with_a_strong_random_secret_at_least_32_chars
JWT_EXPIRATION=36000000

# ── Spring Boot ──────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# ── Docker Registry ──────────────────────────────────────────────────────────
DOCKERHUB_USERNAME=your_dockerhub_username
DOCKERHUB_TOKEN=your_dockerhub_access_token

# ── VPS / Deployment ─────────────────────────────────────────────────────────
VPS_HOST=your.server.ip.address
VPS_USERNAME=deploy
VPS_SSH_PORT=22
# VPS_SSH_KEY is stored as a GitHub Secret (not here)

# ── Frontend (Vite) ──────────────────────────────────────────────────────────
VITE_API_BASE_URL=/api

# ── Vercel (optional — uncomment if using Vercel) ────────────────────────────
# VERCEL_TOKEN=your_vercel_token
# VERCEL_ORG_ID=your_vercel_org_id
# VERCEL_PROJECT_ID=your_vercel_project_id

# ── Netlify (optional — uncomment if using Netlify) ──────────────────────────
# NETLIFY_AUTH_TOKEN=your_netlify_auth_token
# NETLIFY_SITE_ID=your_netlify_site_id
